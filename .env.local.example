# Copy this file to .env.local for local development.
# In Vercel: Project → Settings → Environment Variables, add the same two.
# Find these in Supabase: Project Settings → API.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Notion — powers the Cookbook page. See README "Set up Notion" section.
NOTION_API_KEY=secret_your_internal_integration_token
NOTION_RECIPES_DATABASE_ID=your-database-id
